{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "//": [
        "Local-dev only: resolve the sibling core package straight from source",
        "so typecheck works without a build/link. Delete this `paths` block on",
        "extraction — `@poe2-tree/core` is then a plain published dependency."
      ],
      "@poe2-tree/core": ["../poe2-tree-core/src/index.ts"]
    }
  },
  "include": ["src", "test"]
}
