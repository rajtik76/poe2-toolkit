#!/usr/bin/env bash
#
# Blocks a commit whose message carries an AI-assistant trace — co-author
# trailers, "generated with" footers, the robot emoji. Commit messages in this
# repository must read as human-authored.
#
# This is a commit-msg hook (it inspects the message), the counterpart to the
# pre-commit quality gate.
#
# Enable once per clone:  git config core.hooksPath .githooks
#
set -euo pipefail

msg_file="$1"

# Case-insensitive patterns that mark machine-generated attribution.
patterns=(
  'co-authored-by:.*(claude|anthropic)'
  'generated with.*(claude|copilot)'
  'generated by.*(claude|copilot)'
  '🤖'
  'noreply@anthropic\.com'
  'claude\.ai/code'
)

for pattern in "${patterns[@]}"; do
  if grep -qiE "$pattern" "$msg_file"; then
    echo "✗ commit message contains an AI-assistant trace (matched: /$pattern/i)" >&2
    echo "  Remove the co-author / generated-by lines and the robot emoji, then commit again." >&2
    exit 1
  fi
done
