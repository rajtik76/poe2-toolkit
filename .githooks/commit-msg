#!/usr/bin/env bash
#
# Rejects a commit message that carries ANY AI trace. Messages in this
# repository must read as entirely human-authored: no mention of an AI assistant
# (Claude, ChatGPT, Copilot, ...), no "AI"/"LLM"/"GPT" tokens, no machine
# attribution trailers, no robot emoji.
#
# Portable regex only (macOS BSD grep has no reliable \b): short ambiguous
# tokens are bounded with [^[:alnum:]] so "ai" never matches inside "email",
# "main", "Dubai", etc.; distinctive names are plain substrings.
#
# Enable once per clone:  git config core.hooksPath .githooks
#
set -euo pipefail

msg_file="$1"

# Drop git's comment/scissors lines so the boilerplate help never trips a match.
msg=$(grep -vE '^[[:space:]]*#' "$msg_file" || true)

# Case-insensitive ERE patterns that mark an AI trace.
patterns=(
  '🤖'
  'claude'
  'anthropic'
  'chatgpt'
  'openai'
  'copilot'
  'noreply@anthropic\.com'
  'claude\.ai'
  '(^|[^[:alnum:]])ai([^[:alnum:]]|$)'
  '(^|[^[:alnum:]])llm([^[:alnum:]]|$)'
  '(^|[^[:alnum:]])gpt([^[:alnum:]]|$)'
  'co-authored-by:.*(claude|anthropic|copilot|bot)'
)

for pattern in "${patterns[@]}"; do
  if printf '%s' "$msg" | grep -qiE "$pattern"; then
    echo "✗ commit message contains an AI trace (matched: /$pattern/i)" >&2
    echo "  Messages must read as fully human-authored - remove the mention and commit again." >&2
    exit 1
  fi
done
